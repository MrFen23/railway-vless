# === Soul VPN — VPS конфигурация ===
# Скопируй этот файл в .env и заполни своими значениями:
#   cp .env.example .env

# UUID для доступа к VPN (можно несколько через запятую).
# Сгенерировать новый: uuidgen | tr 'A-Z' 'a-z'
UUIDS=ЗДЕСЬ_ТВОЙ_UUID

# Домен сервера.
DOMAIN=твой-домен.duckdns.org

# Секретный путь WebSocket (клиенты подключаются сюда).
WS_PATH=/yourws

# Секретный URL страницы с QR-кодом.
QR_PATH=/yourqr

# (PORT и сертификаты настраиваются в docker-compose.yml)
